# Supabase — required for run persistence and learning cycle
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # NOT the anon key — use service role

# Admin dashboard password (POST /api/admin/auth)
ADMIN_PASSWORD=change-this-before-deploy

# Shared secret between run_simulation.py and learning_cycle.py
# Must be a random string; never expose to the browser
WORKFLOW_SECRET=change-this-before-deploy

# Vercel AI Gateway — for the LLM analysis in learning_cycle.py
VERCEL_AI_GATEWAY_KEY=your-vercel-ai-gateway-key

# Set automatically by Vercel on deployment — do not set manually in production
# VERCEL_URL=your-deployment.vercel.app
